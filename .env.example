# ============================================================
# FAHIM DZ — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- JWT ----
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_64_CHARS
JWT_EXPIRES_IN=7d

# ---- Firebase ----
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ---- OpenAI ----
# From https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Meta App ----
# From https://developers.facebook.com/apps → Your App → Settings → Basic
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET

# This token is set BY YOU (any string) in Facebook's webhook setup
META_WEBHOOK_VERIFY_TOKEN=fahim_webhook_secret_2024

# ---- WhatsApp Business API ----
WHATSAPP_API_VERSION=v19.0

# ---- CORS ----
# Frontend origin (use * for dev, set exact domain in production)
FRONTEND_URL=http://localhost:3000
